import arcade
import random
from enum import Enum
from Game_state import GameState
from Attack_animation import AttackAnimation, AttackType

# Constantes
LARGEUR_ECRAN = 1200
HAUTEUR_ECRAN = 800
TITRE_ECRAN = "Roche Papier Ciseaux"

JOUEUR_POS = (300, 500)
ORDI_POS = (900, 500)


class Choix(Enum):
    ROCHE = "roche"
    PAPIER = "papier"
    CISEAUX = "ciseaux"


class JeuRPC(arcade.Window):
    def __init__(self):
        super().__init__(LARGEUR_ECRAN, HAUTEUR_ECRAN, TITRE_ECRAN)
        arcade.set_background_color(arcade.color.SEASHELL)

        # État du jeu
        self.etat_jeu = GameState.NOT_STARTED

        # Scores
        self.victoires_joueur = 0
        self.victoires_ordi = 0

        # Choix
        self.choix_joueur = ""
        self.choix_ordi = ""
        self.resultat = "Choisissez une attaque"

        # Sprites personnages
        self.joueur = arcade.Sprite("sprites/IMG_0414.png", scale=0.7)
        self.ordi = arcade.Sprite("sprites/IMG_0413.png", scale=3.4)

        self.joueur.position = JOUEUR_POS
        self.ordi.position = ORDI_POS

        # Liste principale
        self.sprites = arcade.SpriteList()
        self.sprites.append(self.joueur)
        self.sprites.append(self.ordi)

        # Attaques joueur
        self.attaques = {
            "roche": AttackAnimation(AttackType.ROCHE),
            "papier": AttackAnimation(AttackType.PAPIER),
            "ciseaux": AttackAnimation(AttackType.CISEAUX)
        }

        # Attaques ordinateur
        self.attaques_ordi = {
            "roche": AttackAnimation(AttackType.ROCHE),
            "papier": AttackAnimation(AttackType.PAPIER),
            "ciseaux": AttackAnimation(AttackType.CISEAUX)
        }

        # SpriteLists (IMPORTANT)
        self.liste_attaques = arcade.SpriteList()
        self.liste_attaques_ordi = arcade.SpriteList()

        for attaque in self.attaques.values():
            self.liste_attaques.append(attaque)

        for attaque in self.attaques_ordi.values():
            self.liste_attaques_ordi.append(attaque)

        # Positions des attaques
        positions = [(200, 200), (300, 200), (400, 200)]
        for attaque, pos in zip(self.attaques.values(), positions):
            attaque.position = pos

        for attaque in self.attaques_ordi.values():
            attaque.position = (900, 200)

    # -------------------------
    # AFFICHAGE
    # -------------------------
    def on_draw(self):
        self.clear()

        self.sprites.draw()

        # Attaque sélectionnée joueur
        if self.choix_joueur in self.attaques:
            self.attaques[self.choix_joueur].draw()

        # Attaque sélectionnée ordinateur
        if self.choix_ordi in self.attaques_ordi:
            self.attaques_ordi[self.choix_ordi].draw()

        self.afficher_titre()
        self.afficher_choix()

        if self.etat_jeu == GameState.NOT_STARTED:
            self.afficher_message("Appuie sur ESPACE pour commencer")

        elif self.etat_jeu == GameState.ROUND_ACTIVE:
            self.dessiner_cases()
            self.afficher_scores()
            self.afficher_message("Clique sur une attaque")

            # Afficher toutes les attaques disponibles
            self.liste_attaques.draw()

        elif self.etat_jeu == GameState.ROUND_DONE:
            self.dessiner_cases()
            self.afficher_scores()
            self.afficher_resultat()
            self.afficher_message("Appuie sur ESPACE pour continuer")

        elif self.etat_jeu == GameState.GAME_OVER:
            self.dessiner_cases()
            self.afficher_scores()
            self.afficher_fin()

    # -------------------------
    # MÉTHODES D'AFFICHAGE
    # -------------------------
    def afficher_titre(self):
        arcade.draw_text(
            TITRE_ECRAN,
            LARGEUR_ECRAN / 2,
            HAUTEUR_ECRAN - 50,
            arcade.color.BLACK,
            24,
            anchor_x="center",
        )

    def afficher_choix(self):
        arcade.draw_text(
            f"Votre choix : {self.choix_joueur}",
            LARGEUR_ECRAN / 4,
            HAUTEUR_ECRAN / 3,
            arcade.color.BLUE,
            22,
            anchor_x="center",
        )

        arcade.draw_text(
            f"Choix de l'ordinateur : {self.choix_ordi}",
            3 * LARGEUR_ECRAN / 4,
            HAUTEUR_ECRAN / 3,
            arcade.color.RED,
            22,
            anchor_x="center",
        )

    def afficher_scores(self):
        arcade.draw_text(
            f"Joueur : {self.victoires_joueur} | Ordi : {self.victoires_ordi}",
            LARGEUR_ECRAN / 2,
            HAUTEUR_ECRAN - 20,
            arcade.color.BLACK,
            14,
            anchor_x="center",
        )

    def afficher_message(self, texte):
        arcade.draw_text(
            texte,
            LARGEUR_ECRAN / 2,
            700,
            arcade.color.BLACK,
            20,
            anchor_x="center"
        )

    def afficher_resultat(self):
        arcade.draw_text(
            self.resultat,
            LARGEUR_ECRAN / 2,
            HAUTEUR_ECRAN / 2 - 50,
            arcade.color.BLACK,
            18,
            anchor_x="center",
        )

    def afficher_fin(self):
        self.afficher_message("PARTIE TERMINÉE! ESPACE pour rejouer")

        if self.victoires_joueur == 3:
            texte = "Vous avez gagné!"
            couleur = arcade.color.BLUE
        else:
            texte = "Vous avez perdu!"
            couleur = arcade.color.RED

        arcade.draw_text(
            texte,
            LARGEUR_ECRAN / 2,
            650,
            couleur,
            30,
            anchor_x="center"
        )

    def dessiner_cases(self):
        cases = [(161, 239), (261, 339), (361, 439), (861, 939)]
        for gauche, droite in cases:
            arcade.draw_lrbt_rectangle_outline(
                gauche, droite, 161, 239, arcade.color.DARK_GREEN
            )

    # -------------------------
    # LOGIQUE
    # -------------------------
    def on_update(self, delta_time):
        self.liste_attaques.update()
        self.liste_attaques_ordi.update()

    def on_mouse_press(self, x, y, button, modifiers):
        if self.etat_jeu != GameState.ROUND_ACTIVE:
            return

        for nom, attaque in self.attaques.items():
            if attaque.collides_with_point((x, y)):
                self.choix_joueur = nom
                break
        else:
            return

        self.choix_ordi = random.choice([c.value for c in Choix])
        self.resultat = self.determiner_gagnant()

        if self.victoires_joueur >= 3 or self.victoires_ordi >= 3:
            self.etat_jeu = GameState.GAME_OVER
        else:
            self.etat_jeu = GameState.ROUND_DONE

    def on_key_press(self, key, modifiers):
        if key == arcade.key.SPACE:

            if self.etat_jeu == GameState.NOT_STARTED:
                self.etat_jeu = GameState.ROUND_ACTIVE

            elif self.etat_jeu == GameState.ROUND_DONE:
                self.etat_jeu = GameState.ROUND_ACTIVE

            elif self.etat_jeu == GameState.GAME_OVER:
                self.reset_jeu()
                self.etat_jeu = GameState.ROUND_ACTIVE

    def reset_jeu(self):
        self.victoires_joueur = 0
        self.victoires_ordi = 0
        self.choix_joueur = ""
        self.choix_ordi = ""
        self.resultat = "Choisissez une attaque"

    def determiner_gagnant(self):
        if self.choix_joueur == self.choix_ordi:
            return "Égalité!"

        elif (self.choix_joueur == "roche" and self.choix_ordi == "ciseaux") or \
             (self.choix_joueur == "papier" and self.choix_ordi == "roche") or \
             (self.choix_joueur == "ciseaux" and self.choix_ordi == "papier"):

            self.victoires_joueur += 1
            return f"{self.choix_joueur} bat {self.choix_ordi}! Vous gagnez!"

        else:
            self.victoires_ordi += 1
            return f"{self.choix_ordi} bat {self.choix_joueur}! Vous perdez."


def main():
    JeuRPC()
    arcade.run()


if __name__ == "__main__":
    main()
